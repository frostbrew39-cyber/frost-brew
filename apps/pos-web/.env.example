# Production (Vercel): set all three to your Render API HTTPS origin
VITE_API_URL=https://your-api.onrender.com/api/v1
VITE_SOCKET_URL=https://your-api.onrender.com

# Local dev: optional — if unset, POS uses http://<this-host>:10000 (matches API when PORT is unset).
# If you run the API on another port (e.g. 4000), set:
# VITE_API_URL=http://localhost:4000/api/v1
# VITE_SOCKET_URL=http://localhost:4000
